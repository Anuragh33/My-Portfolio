# Resend API key for contact form (https://resend.com)
RESEND_API_KEY=re_xxxxxxxx

# Where contact form messages are delivered (defaults to site email)
CONTACT_TO_EMAIL=anuraghragidimilli@icloud.com

# Must be a sender verified in Resend (NOT your personal inbox).
# Testing: onboarding@resend.dev
# Production: hello@yourdomain.com after domain verification in Resend
CONTACT_FROM_EMAIL=onboarding@resend.dev

# After changing env vars on Vercel, redeploy the project for them to take effect.
